PORT=5000
CLIENT_ORIGIN=http://127.0.0.1:5682

# Optional for full MongoDB persistence. Without this, the backend uses in-memory demo data.
MONGODB_URI=mongodb://127.0.0.1:27017/aurora_test_0093

# ElevenLabs + Twilio are required for real agent creation and outbound calls.
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional Google integrations.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
