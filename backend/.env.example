PORT=5000
CLIENT_ORIGIN=http://127.0.0.1:5682

# Supabase Auth & Database Config
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ElevenLabs + Twilio are required for real agent creation and outbound calls.
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional Google integrations.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vision Phase 2 — webhooks
# Optional shared secret for POST /api/twilio/resolve-inbound (header X-VoiceOS-Secret)
TWILIO_WEBHOOK_SECRET=
# Bearer token for POST /api/internal/voice/call-event (ingest call logs from bridges)
INTERNAL_WEBHOOK_SECRET=
