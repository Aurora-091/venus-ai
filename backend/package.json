{
  "name": "@aurora/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server/index.js",
    "start": "node server/index.js",
    "cf-typegen": "wrangler types --config wrangler.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "wrangler d1 migrations apply DB --local --config wrangler.json",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "better-auth": "1.4.22",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "hono": "4.12.5",
    "mongoose": "^9.4.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@types/node": "^25.3.5",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "wrangler": "^4.71.0"
  }
}
